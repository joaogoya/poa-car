# WordPress .gitignore (wp-content)

# Pastas do Core a ignorar
languages/
upgrade/
upgrade-temp-backup/

# --- Temas ---
# Ignorar todos os temas, exceto o poa-car
themes/*
!themes/poa-car/

#Dentro do tema poa-car, ignorar dependências de build
themes/poa-car/node_modules/
themes/poa-car/.sass-cache/

# --- Arquivos de Sistema e IDE ---
*.log
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# --- Temporários e Backups ---
cache/
temp/
vendor/
*.bak
*.tmp
*.swp
*.sql

# --- Outros ---
.env